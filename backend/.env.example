# ─── Agentic RAG Solution Studio — Environment Configuration ───────────────
# Copy this file to .env and fill in your values.
# The backend reads these automatically via pydantic-settings.

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                    # development | production

# ── OpenAI API ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                  # Required for LLM + embeddings

# ── Model defaults (override per-request via API) ────────────────────────────
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# ── Token cost tracking ($/1k tokens, used for cost estimates) ───────────────
TOKEN_COST_INPUT_PER_1K=0.00015
TOKEN_COST_OUTPUT_PER_1K=0.0006

# ── Storage ──────────────────────────────────────────────────────────────────
VECTOR_STORE=chroma                    # Only chroma is supported currently
# UPLOAD_DIR and VECTOR_STORE_DIR default to ./uploads and ./vector_store
# Override only if running outside the backend/ directory:
# UPLOAD_DIR=/data/uploads
# VECTOR_STORE_DIR=/data/vector_store

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Add your frontend URL if hosting separately.
# Default covers localhost dev ports + the FastAPI static-file server.
# CORS_ORIGINS=["http://localhost:8000","http://localhost:3000"]
